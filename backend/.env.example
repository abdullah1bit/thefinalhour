# Copy this file to backend/.env for local development.
# Keep real values in your private machine or deployment provider only.

PORT=3000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_BASE_URL="https://your-domain.com"

# Optional: required only for admin image uploads.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: used only if future backend AI features are enabled.
OPENAI_API_KEY=""

# Used by seed scripts when creating the first admin account.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
