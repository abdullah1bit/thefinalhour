generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Better Auth Tables ───────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Content Tables ───────────────────────────────────────────────

model Sign {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  source      String
  status      String
  category    String?
  period      String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MajorSign {
  id          String           @id @default(cuid())
  slug        String           @unique
  number      Int              @unique
  title       String
  arabicTitle String
  subtitle    String
  description String
  sources     String           // JSON string array
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  details MajorSignDetail[]
}

model MajorSignDetail {
  id          String    @id @default(cuid())
  majorSignId String
  label       String
  content     String
  sortOrder   Int       @default(0)

  majorSign MajorSign @relation(fields: [majorSignId], references: [id], onDelete: Cascade)
}

model GlossaryTerm {
  id         String   @id @default(cuid())
  term       String   @unique
  arabic     String?
  definition String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model QuranicVerse {
  id        String   @id @default(cuid())
  reference String   @unique
  text      String
  context   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScholarlyWork {
  id        String   @id @default(cuid())
  title     String
  author    String
  deathDate String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimelineEvent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  status      String
  description String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Interpretation {
  id                     String   @id @default(cuid())
  prophecy               String
  modernInterpretation   String
  scholarlyCaution       String
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
