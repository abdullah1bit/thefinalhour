---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/astro/PageHeader.astro";
import SearchIsland from "@/components/SearchIsland";
---

<BaseLayout title="Search" description="Search signs, glossary terms, verses, scholarly works, and timeline events on The Final Hour." path="/search/">
  <main>
    <PageHeader title="Search" subtitle="Search the static public index without sending every query to the database." />
    <section class="mx-auto max-w-5xl px-4 py-12 lg:px-8 lg:py-16">
      <SearchIsland client:load />
    </section>
  </main>
</BaseLayout>
