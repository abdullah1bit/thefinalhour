---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/astro/PageHeader.astro";
import SignCard from "@/components/astro/SignCard.astro";
import SectionDivider from "@/components/astro/SectionDivider.astro";
import { getPublicContent, groupBy } from "@/lib/public-content";

const { signs } = await getPublicContent();
const groups = groupBy(signs, (sign) => sign.status);
const ordered = ["fulfilled", "unfolding", "approaching"];
---

<BaseLayout title="Signs of the End Times" description="Browse fulfilled, unfolding, and approaching signs of the end times in Islam." path="/signs/">
  <main>
    <PageHeader title="Signs of the End Times" subtitle="A structured collection of signs organized by status, period, category, and source." />
    <section class="mx-auto max-w-5xl px-4 py-12 lg:px-8 lg:py-16">
      <div class="mb-8 grid gap-3 md:grid-cols-3">
        <a class="rounded-lg border border-fulfilled/30 bg-card/60 p-4 hover:bg-card" href="/signs/fulfilled/">Fulfilled ({groups.fulfilled?.length || 0})</a>
        <a class="rounded-lg border border-unfolding/30 bg-card/60 p-4 hover:bg-card" href="/signs/unfolding/">Unfolding ({groups.unfolding?.length || 0})</a>
        <a class="rounded-lg border border-approaching/30 bg-card/60 p-4 hover:bg-card" href="/signs/approaching/">Approaching ({groups.approaching?.length || 0})</a>
      </div>
      {ordered.map((status) => (
        groups[status]?.length ? (
          <section class="py-8">
            <h2 class="mb-4 font-heading text-2xl font-semibold capitalize text-foreground">{status} Signs</h2>
            <div class="grid gap-3 md:grid-cols-2">{groups[status].map((sign) => <SignCard sign={sign} compact />)}</div>
            <a href={`/signs/${status}/`} class="mt-5 inline-flex text-sm text-primary/80 hover:text-primary">View {status} signs</a>
            <SectionDivider />
          </section>
        ) : null
      ))}
    </section>
  </main>
</BaseLayout>
