---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/astro/PageHeader.astro";
import GlossaryTermCard from "@/components/astro/GlossaryTermCard.astro";
import ReferenceCards from "@/components/astro/ReferenceCards.astro";
import { getPublicContent } from "@/lib/public-content";

const { glossary, verses, scholarlyWorks } = await getPublicContent();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "Islamic Eschatology Glossary",
  hasDefinedTerm: glossary.map((term) => ({
    "@type": "DefinedTerm",
    name: term.term,
    description: term.definition,
  })),
};
---

<BaseLayout title="Glossary of Terms" description="A dictionary of key Arabic terms and concepts relating to Islamic eschatology." path="/glossary/" jsonLd={jsonLd}>
  <main>
    <PageHeader title="Glossary & References" subtitle="Key terms, Quranic verses, and scholarly works" />
    <section class="mx-auto max-w-5xl px-4 py-12 lg:px-8 lg:py-16">
      <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="gold-text font-heading text-2xl font-bold">Key Terms</h2>
          <p class="mt-2 text-sm text-muted-foreground">{glossary.length} terms available as indexable pages.</p>
        </div>
        <a href="/search/" class="inline-flex rounded-md border border-border/50 px-4 py-2 text-sm text-primary/80 hover:border-primary/40 hover:text-primary">
          Search all content
        </a>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {glossary.map((term) => <GlossaryTermCard term={term} />)}
      </div>

      <div class="mt-16">
        <ReferenceCards verses={verses} works={scholarlyWorks} />
      </div>
    </section>
  </main>
</BaseLayout>
