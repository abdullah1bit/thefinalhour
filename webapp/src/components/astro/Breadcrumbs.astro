---
interface Crumb {
  href: string;
  label: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-5xl px-4 pt-8 text-sm text-muted-foreground lg:px-8">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 ? <span aria-hidden="true">/</span> : null}
        {index === items.length - 1 ? (
          <span class="text-foreground">{item.label}</span>
        ) : (
          <a class="hover:text-primary" href={item.href}>{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
