---
import type { Sign } from "@/lib/types";
import { imageUrl } from "@/lib/public-content";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  sign: Sign;
  compact?: boolean;
}

const { sign, compact = false } = Astro.props;
let imgSettings: { objectFit?: string; objectPosition?: string; size?: string } | null = null;
try {
  imgSettings = sign.imageSettings ? JSON.parse(sign.imageSettings) : null;
} catch {
  imgSettings = null;
}
const img = imageUrl(sign.imageUrl);
const height = imgSettings?.size === "sm" ? "120px" : imgSettings?.size === "lg" ? "260px" : "180px";
---

<article class="group rounded-lg border border-border/50 bg-card/60 transition-colors hover:border-primary/30 hover:bg-card">
  <details class="peer" open={!compact}>
    <summary class="flex cursor-pointer list-none items-start gap-3 p-4">
      <div class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-primary"></div>
      <div class="min-w-0 flex-1">
        <div class="mb-1 flex flex-wrap items-center gap-2">
          <h2 class="font-heading text-lg font-semibold leading-tight text-foreground">
            <a href={`/signs/${sign.slug}/`} class="hover:text-primary">{sign.title}</a>
          </h2>
          <StatusBadge status={sign.status} />
        </div>
        <p class="text-xs text-muted-foreground">{sign.source}</p>
      </div>
      <span class="text-muted-foreground">v</span>
    </summary>
    <div class="border-t border-border/30 px-4 pb-4 pt-3">
      {img ? (
        <div class="mb-3 w-full overflow-hidden rounded-md" style={`height: ${height}`}>
          <img
            src={img}
            alt={sign.title}
            loading="lazy"
            class="h-full w-full"
            style={`object-fit: ${imgSettings?.objectFit || "cover"}; object-position: ${imgSettings?.objectPosition || "center"};`}
          />
        </div>
      ) : null}
      <p class="text-sm leading-relaxed text-muted-foreground">{sign.description}</p>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
        {sign.category ? <span>Category: {sign.category}</span> : null}
        {sign.period ? <span>Period: {sign.period}</span> : null}
      </div>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={`/signs/${sign.slug}/`} class="text-sm text-primary/80 transition-colors hover:text-primary">
          View detail page
        </a>
        {sign.sourceUrl ? (
          <a href={sign.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-primary/80 transition-colors hover:text-primary">
            {sign.sourceLabel || "Read source"}
          </a>
        ) : null}
      </div>
    </div>
  </details>
</article>
