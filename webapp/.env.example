# Copy this file to webapp/.env for local development.
# VITE_* values are exposed to the browser, so do not put private secrets here.

# Only needed when the frontend and backend run on different local ports.
VITE_BACKEND_URL="http://localhost:3000"

# Used by Astro for canonical URLs and sitemap generation.
PUBLIC_SITE_URL="https://thefinalhour.vercel.app"

# Optional public analytics config.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"

